# ================================================================
# ASPIDUS CRM — Environment variables
# ================================================================
# KOPIRAJ ovaj fajl u ".env" (bez .example) na produkcijskom serveru
# i popuni pravim vrednostima. NIKAD ne commit-uj .env u git.
#
# Na PythonAnywhere: Web tab → Files → dodaj u source (~/mysite/.env)
# Zatim u WSGI konfiguraciji dodaj:
#   from dotenv import load_dotenv
#   load_dotenv('/home/USERNAME/mysite/.env')
# ili sam Flask config pokupi kroz os.getenv() (već imamo).
# ================================================================

# ---- Aspidus admin CRM (postojeći sistem, ne diramo) ----
SECRET_KEY=<generisan automatski, čuva se u instance/secret.key>
ENCRYPTION_KEY=<Fernet ključ, čuva se u vault.key>
ADMIN_USERNAME=<tvoj admin username>
ADMIN_PASSWORD=<tvoja admin lozinka>
DATA_DIR=/home/USERNAME/mysite/data
SESSION_COOKIE_SECURE=true

# ---- Supabase (NOVO — za portal migraciju) ----
# Project Settings → API u Supabase Dashboard
SUPABASE_URL=https://gceaznutofvqbuyypjlh.supabase.co

# Publishable (anon) key — bezbedno u frontend
SUPABASE_ANON_KEY=sb_publishable_XXXX

# Secret (service_role) key — NIKAD u frontend, NIKAD u git.
# Ima full DB pristup, bypass-uje RLS.
SUPABASE_SERVICE_ROLE_KEY=sb_secret_XXXX

# JWT Secret — Project Settings → API → JWT Settings → JWT Secret
# Koristi se za offline verifikaciju JWT tokena bez zvanja Supabase API-ja.
SUPABASE_JWT_SECRET=<JWT secret iz dashboard-a>

# Postgres connection string (Session mode, port 5432 — za psycopg)
# Uzeti iz: Project Settings → Database → Connection string → URI
# Password je DB password koji si postavio pri kreiranju projekta.
SUPABASE_DB_URL=postgresql://postgres:<DB_PASSWORD>@db.gceaznutofvqbuyypjlh.supabase.co:5432/postgres

# ---- Feature flags za postepenu migraciju ----
# Ovi flag-ovi omogućavaju rollback bez restart-a servera.
# Postavljaju se u Admin CRM → Settings → Migration.
USE_SUPABASE_AUTH=false        # Faza 1: postavi true kad počneš auth switch
USE_SUPABASE_STORAGE=false     # Faza 2: postavi true kad počneš storage switch
USE_SUPABASE_DB=false          # Faza 4: postavi true kad počneš data switch
DUAL_WRITE_MODE=true           # Faza 4: piše i u SQLite i u Postgres dok se ne završi

# ---- Postojeće opcione integracije (nista se ne menja) ----
# RESEND_API_KEY, POSTMARK_API_KEY, itd. ostaju kako su bili.
