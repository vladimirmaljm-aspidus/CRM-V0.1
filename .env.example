# ================================================================
# ASPIDUS CRM — Environment variables (.env)
# ================================================================
# UPUTSTVO: kopiraj ovaj fajl u ".env" (bez .example) na tvom
# PythonAnywhere serveru, u ISTOM folderu gde ti je app.py.
# NIKAD .env NE COMMITUJ u git (već je u .gitignore).
# ================================================================

# ================================================================
#  ADMIN CRM (postojeći sistem — ne diramo, ostaje isto)
# ================================================================
SECRET_KEY=<Ostavi prazno, generiše se automatski i čuva u instance/secret.key>
ENCRYPTION_KEY=<Ostavi prazno, čuva se u vault.key>
ADMIN_USERNAME=<tvoj admin username za CRM>
ADMIN_PASSWORD=<tvoja admin lozinka za CRM>
DATA_DIR=/home/<tvoj-pa-username>/mysite
SESSION_COOKIE_SECURE=true

# ================================================================
#  SUPABASE — NOVO za portal migraciju
# ================================================================

# --- Osnovni endpoint tvog projekta ---
# Nalaziš ga u: Supabase Dashboard → Project Settings → API → "Project URL"
SUPABASE_URL=https://gceaznutofvqbuyypjlh.supabase.co

# --- Publishable (anon) ključ ---
# Bezbedan je za frontend (SPA čita ga).
# Supabase Dashboard → Project Settings → API → "Project API keys" → "anon public"
# ILI (novi format): Project Settings → API Keys → "Publishable"
SUPABASE_ANON_KEY=<sb_publishable_... — nalepi svoj publishable key>
# Format primer (nije stvarni ključ): sb_publishable_AbCdEfGhIjKlMnOp_QrStUvWxYz

# --- Secret (service_role) ključ ---
# ⚠ NIKAD u frontend, NIKAD u git. Ima potpuni DB pristup, bypass-uje RLS.
# Supabase Dashboard → Project Settings → API → "Project API keys" → "service_role" (klik na "Reveal")
# ILI (novi format): Project Settings → API Keys → "Secret"
SUPABASE_SERVICE_ROLE_KEY=<sb_secret_... — nalepi svoj secret key>
# Format primer (nije stvarni ključ): sb_secret_AbCdEfGhIjKl_MnOpQrStUv_WxYz1234567890

# --- JWT Secret (za offline verifikaciju JWT tokena) ---
# Ovo je SEPARATNA vrednost od gornjih ključeva.
# Supabase Dashboard → Project Settings → API → skroluj dole do sekcije
# "JWT Settings" → polje "JWT Secret" (klikni "Reveal" pored njega).
# Izgleda kao dugačak nasumičan string (~40+ karaktera).
SUPABASE_JWT_SECRET=<POPUNI OVO — vidi uputstvo iznad>

# --- Postgres connection string ---
# Nalaziš ga u: Supabase Dashboard → Project Settings → Database →
# sekcija "Connection string" → izaberi "URI" (ne "PSQL"), izaberi
# tab "Session mode" (port 5432).
# Kopiraj ceo string, i **umesto [YOUR-PASSWORD]** stavi DB lozinku
# koju si postavio kad si kreirao projekat.
#
# Ako si zaboravio DB lozinku: Project Settings → Database →
# "Reset database password" → generiši novu → sačuvaj je u password
# manager i nalepi ovde.
#
# Ceo string treba da izgleda otprilike ovako:
# postgresql://postgres:<TVOJA_DB_LOZINKA>@db.gceaznutofvqbuyypjlh.supabase.co:5432/postgres
SUPABASE_DB_URL=<POPUNI OVO — vidi uputstvo iznad>

# ================================================================
#  FEATURE FLAGS — za postepeno prebacivanje na Supabase
# ================================================================
# SVI OSTAJU FALSE ZA SADA. Kad krenemo sa Fazom 1, ja ću ti reći
# koji da postaviš na true. Instant rollback = vratiš na false i
# reload PythonAnywhere web app-a.

USE_SUPABASE_AUTH=false
USE_SUPABASE_STORAGE=false
USE_SUPABASE_DB=false
DUAL_WRITE_MODE=false

# ================================================================
#  OPTIONS (postojeće — ne diraj ako već koristiš)
# ================================================================
# RESEND_API_KEY=
# POSTMARK_API_KEY=
# ...
