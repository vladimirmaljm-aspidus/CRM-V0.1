uploads/*
!uploads/.gitkeep
portal_uploads/*
!portal_uploads/.gitkeep

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
env/
.env

# Node
node_modules/

# OS / IDE
.DS_Store
Thumbs.db
.idea/
.vscode/

